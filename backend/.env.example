DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSLMODE=require
SERVER_PORT=8080
# Danh sách domain FE được phép gọi API (khớp chính xác origin, không dùng "*" vì
# AllowCredentials=true) — deploy thật phải liệt kê đúng domain Vercel, không chỉ localhost.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Local (FE/BE cùng site): giữ Secure=false, SameSite=Lax là đủ để cookie refresh_token gửi được.
# Deploy cross-site (FE Vercel, BE Render khác domain): BẮT BUỘC đổi thành COOKIE_SECURE=true và
# COOKIE_SAME_SITE=None — nếu không, browser sẽ không bao giờ gửi cookie refresh_token kèm request
# cross-site (XHR/fetch, không phải link điều hướng), khiến /auth/refresh và /auth/logout luôn lỗi
# thiếu cookie trên prod (F5 luôn mất session, logout không disconnect được).
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
JWT_SECRET=change-me
TEAMS_CLIENT_ID=
TEAMS_TENANT_ID=common
GAME_DEFAULT_MAP_CODE=village_adventure
